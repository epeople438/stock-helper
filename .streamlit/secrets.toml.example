# 部署到 Streamlit Cloud 时，把下面内容填好后粘贴到
# Streamlit Cloud 的 App → Settings → Secrets 里（不要提交真实值到 GitHub）。
#
# 本地想测门禁，可把本文件复制成 .streamlit/secrets.toml 并填值（该文件已被 .gitignore 忽略）。

# 进入应用的共享暗号（朋友进门要输）
APP_PASSCODE = "改成你们的暗号"

# Supabase 数据库（自选股按人持久化存这里）
# 在 supabase.com 建项目后，Project Settings → API 里能找到
SUPABASE_URL = "https://xxxx.supabase.co"
SUPABASE_KEY = "你的 anon public key"
